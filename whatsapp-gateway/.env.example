PORT=3000
HOST=127.0.0.1

# Must match Laravel BAILEYS_GATEWAY_SECRET (non-empty)
BAILEYS_GATEWAY_SECRET=change-me-to-a-long-random-string

# Laravel site URL — used for receipt webhooks (auto POSTs via 127.0.0.1 + Host header)
LARAVEL_APP_URL=https://your-domain.com

# Optional overrides (usually NOT needed if LARAVEL_APP_URL is set):
# LARAVEL_RECEIPT_INTERNAL_URL=http://127.0.0.1/api/v1/webhooks/baileys-message-status
# LARAVEL_WEBHOOK_HOST=your-domain.com
# LARAVEL_RECEIPT_LOOPBACK_PORT=80
# LARAVEL_RECEIPT_USE_PUBLIC_URL=true
# LARAVEL_RECEIPT_WEBHOOK_URL=https://your-domain.com/api/v1/webhooks/baileys-message-status
# RECEIPT_DEBUG=true

SESSIONS_DIR=./sessions
ENABLE_QR_SETUP_PAGE=true

# Reconnect resilience (0 = never auto-wipe credentials on reconnect failure)
RECONNECT_WIPE_THRESHOLD=0
# Backoff delays in ms between reconnect retries: 30s, 2m, 10m
RECONNECT_BACKOFF_MS=30000,120000,600000

# How often to probe registered sessions with a dead socket (0 = disabled)
CONNECTED_SESSION_WATCHDOG_MS=45000

# Optional: forward inbound WhatsApp messages to Laravel
# LARAVEL_WEBHOOK_URL=https://your-domain.com/api/v1/whatsapp-webhook
